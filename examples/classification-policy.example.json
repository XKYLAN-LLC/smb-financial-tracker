{
  "schemaVersion": "0.1.0",
  "policy": {
    "id": "sample-classification-policy-2026",
    "label": "Sample classification policy",
    "taxYear": 2026,
    "currency": "USD",
    "privacy": "Synthetic example. Real policies belong under private/profile/ and should reflect user and professional guidance."
  },
  "amountRules": {
    "ledgerAmount": "Store amounts as positive numbers. Row type controls whether a value is revenue, expense, deduction, or info only.",
    "businessPct": "Use 0 through 100. Use 100 only when the item is clearly business and supported. Use a documented allocation for mixed-use items or mark CPA review.",
    "deductiblePct": "Do not invent current-year tax limitations. Store user or CPA-approved treatment in private policy notes and flag uncertain items."
  },
  "statuses": [
    "Supported",
    "Estimate",
    "Needs support",
    "CPA review",
    "Exclude",
    "Info only"
  ],
